            getAllUsers: function(e) { this._call('getAllUsers', e); },
            getActionLogs: function(e, f) { this._call('getActionLogs', e, f); },
            saveUser: function(e, d) { this._call('saveUser', e, d); },
            deleteUser: function(e, u) { this._call('deleteUser', e, u); },
            sendMessageToUser: function(...args) { this._call('sendMessageToUser', ...args); },
            changeUserPassword: function(...args) { this._call('changeUserPassword', ...args); },
            getMessagesForUser: function(e) { this._call('getMessagesForUser', e); },
            markMessagesAsRead: function(e) { this._call('markMessagesAsRead', e); },
            saveConfiguracaoPopUp: function(e, c) { this._call('saveConfiguracaoPopUp', e, c); },
            getConfiguracaoPopUp: function() { this._call('getConfiguracaoPopUp'); },
            getGlobalChatHistory: function(e) { this._call('getGlobalChatHistory', e); },
