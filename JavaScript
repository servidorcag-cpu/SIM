document.addEventListener('DOMContentLoaded', function() {
    try {
        if (typeof google !== 'undefined' && google.charts) {
            google.charts.load('current', {
                packages:['corechart'],
                callback: () => { isChartsLoaded = true; }
            });
        }
    } catch (e) { console.error("Erro ao carregar Google Charts:", e); }

    try { setupGlobalEventListeners(); } catch (e) { console.warn("Aviso em Listeners Globais", e); }
    try { setupAllModalListeners(); } catch (e) { console.warn("Aviso em Listeners de Modal", e); }
    try { setupProgramasModalListeners(); } catch (e) { console.warn("Aviso em Listeners de Programas", e); }
    try { setupChatWindowDrag(); } catch (e) { console.warn("Aviso no arrasto do Chat", e); }

    try {
        const savedSession = loadSession();
        if (savedSession) {
            restoreSession(savedSession);
        } else {
            setTimeout(() => {
                if (typeof google !== 'undefined' && google.script) {
                    loadPopUpOnLoginScreen();
                }
            }, 500);
        }
    } catch (e) { 
        console.error("Falha ao processar sessão salva:", e); 
    }

    window.addEventListener('focus', () => {
        if (loggedUser) requestWakeLock();
    });
});

function setupGlobalEventListeners() {
    const enterLogin = (e) => {
        if (e.key === 'Enter') handleLogin();
    };
    document.getElementById('login-nome')?.addEventListener('keydown', enterLogin);
    document.getElementById('login-senha')?.addEventListener('keydown', enterLogin);

    document.querySelector('.tabs')?.addEventListener('click', (event) => {
      const tabButton = event.target.closest('.tab-button');
      if (tabButton && tabButton.dataset.tab) openTab(tabButton.dataset.tab);
    });

    document.querySelectorAll('.sub-tabs').forEach(subTabNav => {
      subTabNav.addEventListener('click', (event) => {
        const subTabButton = event.target.closest('.sub-tab-button');
        if (subTabButton) {
            const parentTabContent = subTabButton.closest('.tab-content');
            if (parentTabContent) openSubTab(subTabButton.dataset.subTab, parentTabContent.id);
        }
      });
    });

    const chatInput = document.getElementById('chat-input-text');
    if (chatInput) {
        chatInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendChatMessage();
            }
        });
    }

    const chatWindow = document.getElementById('chat-floating-window');
    chatWindow?.addEventListener('click', stopChatAlarm);
    chatWindow?.addEventListener('focusin', stopChatAlarm);
}

function saveSession(userData) {
    try { STORAGE_API.setItem(SESSION_KEY, JSON.stringify(userData)); } catch (e) {}
}

function loadSession() {
    try { return JSON.parse(STORAGE_API.getItem(SESSION_KEY)); } catch (e) { return null; }
}

function clearSession() {
    [SESSION_KEY, REMOTE_ALARM_KEY, CHAT_UNREAD_KEY, DRAFT_OS_KEY, HP_ALARM_KEY, HP_SEEN_KEY, VIEWED_OS_KEY].forEach(key => {
        try { STORAGE_API.removeItem(key); } catch (e) {}
    });
    clearOSDraft();
}

function restoreSession(sessionData) {
    loggedUser = sessionData;
    
    const userDisplay = document.getElementById('user-display');
    if(userDisplay) userDisplay.textContent = sessionData.nome;
    
    document.getElementById('login-container').style.display = 'none';
    document.getElementById('main-panel').style.display = 'block';
    
    const chatFab = document.getElementById('chat-fab');
    if(chatFab) chatFab.style.display = 'flex';
    
    configureAcessLevel(sessionData.nivel);
    
    const osForm = document.getElementById('os-form');
    if(osForm) osForm.innerHTML = '<p>Carregando dados iniciais...</p>';
    
    const osTableTbody = document.querySelector('#os-table tbody');
    if(osTableTbody) osTableTbody.innerHTML = '<tr><td colspan="9">Carregando...</td></tr>';

    showLoading();
    
    if (typeof google !== 'undefined' && google.script) {
        google.script.run
            .withSuccessHandler(handleInitialData)
            .withFailureHandler(err => {
                hideLoading();
                alert("Falha ao carregar dados. Por favor, recarregue a página.");
            })
            .getInitialData(sessionData.email);
    }

    requestWakeLock();
    document.addEventListener('visibilitychange', handleWakeLockVisibility);
}

function handleInitialData(data) {
    hideLoading();
    if (data.error) {
        alert("Erro no servidor ao buscar dados: " + data.error);
        return;
    }

    setoresList = data.setores || [];
    tecnicosList = data.tecnicos || [];
    allUserNames = data.allUserNames || [];

    renderGerarOSForm();
    if (['admin', 'gerente', 'tecnico', 'recepcao'].includes(loggedUser.nivel.toLowerCase())) {
        loadPainelOSFilters();
    }
    
    setupDatePickers();

    if (data.chatHistory) {
        cachedChatMessages = data.chatHistory;
        const newestMsg = findNewestMessage(cachedChatMessages);
        lastChatMessageId = newestMsg ? newestMsg.id : 0;
        if (isChatWindowOpen) renderChatDOM(cachedChatMessages, true);
    }

    if (data.painelOS) renderOSDataTable(data.painelOS);
    
    let defaultTab = 'gerar-os';
    const nivel = loggedUser.nivel.toLowerCase();
    
    if (['admin', 'gerente'].includes(nivel)) {
        defaultTab = 'dashboard';
    } else if (['tecnico', 'recepcao'].includes(nivel)) {
        defaultTab = 'painel-os';
    }
    openTab(defaultTab, true);

    if (defaultTab === 'dashboard') {
        loadStatistics();
    }

    if (data.hasUnreadPrivateMessages) {
        const bell = document.getElementById('private-message-bell');
        if(bell) bell.style.display = 'flex';
    }

    if (data.expirationWarningDays) {
        const days = data.expirationWarningDays;
        showToast(`<strong>ATENÇÃO:</strong> A licença do sistema expira em <strong>${days} dia${days > 1 ? 's' : ''}</strong>.`, [], 'high-priority');
    }
    
    if (data.expirationDateFormatted) {
        const valDate = document.getElementById('system-validity-date');
        if(valDate) valDate.textContent = data.expirationDateFormatted;
    }

    startPollingServices();
}

function handleLogin() {
    const nomeEl = document.getElementById('login-nome');
    const senhaEl = document.getElementById('login-senha');

    if (!nomeEl || !senhaEl) return;

    const nome = nomeEl.value.trim();
    const senha = senhaEl.value;

    if (!nome || !senha) {
        showMessage('login-message', 'Preencha Nome e Senha.', false);
        return;
    }

    const loginBtn = document.querySelector('#login-container .btn-primary') || document.querySelector('#login-container button');
    if(loginBtn) loginBtn.textContent = 'A verificar...';
    showLoading();

    if (typeof google !== 'undefined' && google.script) {
        google.script.run
            .withSuccessHandler(response => {
                hideLoading();
                if(loginBtn) loginBtn.textContent = 'Entrar';
                if (response && response.status === 'sucesso') {
                    if (!audioCtx) {
                        try { audioCtx = new(window.AudioContext || window.webkitAudioContext)(); } 
                        catch (e) { console.warn("Web Audio API não suportada."); }
                    }
                    loggedUser = response;
                    saveSession(response);
                    restoreSession(response);
                } else {
                    showMessage('login-message', response ? response.mensagem : 'Usuário ou senha incorretos.', false);
                }
            })
            .withFailureHandler(err => {
                hideLoading();
                if(loginBtn) loginBtn.textContent = 'Entrar';
                showMessage('login-message', 'Erro de conexão com o servidor.', false);
            })
            .verificarLogin(nome, senha);
    }
}

function logout() {
    stopAllPollingServices();
    stopAllAudioLoops();

    const chatWin = document.getElementById('chat-floating-window');
    if(chatWin) chatWin.style.display = 'none';
    
    const chatFab = document.getElementById('chat-fab');
    if(chatFab) chatFab.style.display = 'none';
    
    document.getElementById('login-container').style.display = 'flex';
    document.getElementById('main-panel').style.display = 'none';
    document.getElementById('login-nome').value = '';
    document.getElementById('login-senha').value = '';
    
    loggedUser = null;
    isChatWindowOpen = false;
    clearSession();
    releaseWakeLock();
    document.removeEventListener('visibilitychange', handleWakeLockVisibility);
    
    loadPopUpOnLoginScreen();
}

function configureAcessLevel(nivel) {
    const n = nivel.toLowerCase();
    const rules = {
        'tab-btn-dashboard': ['admin', 'gerente'],
        'tab-painel-os': ['admin', 'gerente', 'tecnico', 'recepcao'],
        'tab-diario-tecnico': ['tecnico', 'admin', 'gerente'],
        'tab-relatorios': ['admin', 'gerente'],
        'tab-configuracoes': ['admin'],
        'tab-minha-conta': ['admin', 'gerente', 'tecnico', 'recepcao'],
        'tab-programas': ['admin', 'gerente', 'tecnico'],
        'btn-indicadores-estatisticas': ['admin', 'gerente'],
        'btn-demonstrativos-despesas': ['admin', 'gerente'],
        'btn-avaliacao-desempenho': ['admin', 'gerente']
    };

    for (const id in rules) {
        const element = document.getElementById(id);
        if (element) {
            element.style.display = rules[id].includes(n) ? 'flex' : 'none';
        }
    }
}

