function saveUser() {
    const email = document.getElementById('user-email').value;
    const nome = document.getElementById('user-nome').value;
    const nivel = document.getElementById('user-nivel').value;
    const senha = document.getElementById('user-senha').value;

    if (!email || !nome) { showMessage('user-modal-message', 'Email e Nome são obrigatórios.', false); return; }

    const userData = { email, nome, nivel, senha };
    showLoading();
    google.script.run.withSuccessHandler(res => {
        hideLoading();
        if (res.status === 'sucesso') {
            showMessage('user-modal-message', res.message, true);
            loadAdminUsersTable();
            setTimeout(() => document.getElementById('user-admin-modal').style.display = 'none', 1000);
        } else {
            showMessage('user-modal-message', res.message, false);
        }
    }).withFailureHandler(() => hideLoading()).saveUser(loggedUser.email, userData);
}

function deleteUser() {
    const email = document.getElementById('user-email').value;
    if (!email || !confirm(`Tem certeza que deseja excluir o usuário ${email}?`)) return;
    
    showLoading();
    google.script.run.withSuccessHandler(res => {
        hideLoading();
        if (res.status === 'sucesso') {
            document.getElementById('user-admin-modal').style.display = 'none';
            loadAdminUsersTable();
        } else {
            showMessage('user-modal-message', res.message, false);
        }
