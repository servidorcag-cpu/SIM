function imprimirRelatorioLogs() {
    const table = document.getElementById('admin-logs-table');
    const userSelect = document.getElementById('rel-logs-filter-user');
    const userText = userSelect ? (userSelect.value === 'Todos' ? 'Todos' : userSelect.options[userSelect.selectedIndex].text) : 'Todos';
    const dateRange = logsReportDatePicker.getDateRange();
    let dateText;
    if (dateRange.key === 'custom') {
        const start = formatDateToDDMMYYYY(dateRange.startDate);
        const end = formatDateToDDMMYYYY(dateRange.endDate);
        dateText = (start && end) ? `${start} a ${end}` : 'Personalizado';
    } else {
        dateText = logsReportDatePicker.predefinedRanges[dateRange.key];
    }

    const title = `Relatório de Logs de Atividades`;
    const subtitle = `Filtros: Usuário - ${userText} | Período - ${dateText}`;
    
    let printWindow = window.open('', '_blank');
    printWindow.document.write('<html><head><title>' + title + '</title>');
    printWindow.document.write('<style>body{font-family:Arial,sans-serif;font-size:12px} table{width:100%;border-collapse:collapse} th,td{border:1px solid #ddd;padding:8px;text-align:left} th{background-color:#f2f2f2} h1,p{margin-bottom:10px;}</style>');
    printWindow.document.write('</head><body>');
    printWindow.document.write('<h1>' + title + '</h1>');
    printWindow.document.write('<p>' + subtitle + '</p>');
    printWindow.document.write(table.outerHTML);
    printWindow.document.write('</body></html>');
    printWindow.document.close();
    printWindow.focus();
    setTimeout(() => { printWindow.print(); }, 500);
}

