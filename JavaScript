function sendChatMessage() {
    const input = document.getElementById('chat-input-text');
    if(!input) return;
    const msg = input.value.trim();
    
    if (msg === "" && chatAttachments.length === 0) return;

    input.value = '';
    
    google.script.run
        .withSuccessHandler(() => {
            chatAttachments = [];
            renderChatAttachmentsPreview();
            cancelReply();
        })
        .withFailureHandler(err => {
            input.value = msg; 
            alert('Falha ao enviar mensagem: ' + JSON.stringify(err));
        })
        .sendChatMessageAdvanced(loggedUser.email, 'global', msg, chatAttachments, chatReplyContext);
}

function loadGlobalChatHistory(forceOpen = false, playSound = true) {
    if (!loggedUser) return;
    google.script.run.withSuccessHandler(messages => {
        cachedChatMessages = messages;
        const newestMsg = findNewestMessage(messages);
        
        if (newestMsg && newestMsg.id > lastChatMessageId) {
            lastChatMessageId = newestMsg.id;
            if (isChatWindowOpen) {
                renderChatDOM(messages, false);
            } else if (!newestMsg.isMe) {
                const badge = document.getElementById('chat-unread-badge');
                if(badge) badge.style.display = 'block';
                if(playSound) playNotificationSound();
            }
        }
        if (forceOpen) renderChatDOM(messages, true);
    }).getGlobalChatHistory(loggedUser.email);
}

function renderChatDOM(messages, fullRender = false) {
    const container = document.getElementById('chat-history-container');
    if(!container) return;
    if (fullRender) container.innerHTML = '';
    
    const fragment = document.createDocumentFragment();
    messages.forEach(msg => {
        if (document.getElementById(`msg-${msg.id}`)) return; 
        fragment.appendChild(createMessageElement(msg));
    });

    const shouldScroll = (container.scrollTop + container.clientHeight) >= (container.scrollHeight - 100);
    container.appendChild(fragment);

    if (shouldScroll || fullRender) {
        container.scrollTop = container.scrollHeight;
    }
}

function createMessageElement(msg) {
    const wrapper = document.createElement('div');
    wrapper.className = 'chat-message-wrapper';
    wrapper.id = `msg-${msg.id}`;

    const bubble = document.createElement('div');
    bubble.className = `msg-bubble ${msg.isMe ? 'msg-sent' : 'msg-received'}`;

    if (!msg.isMe) {
        const sender = document.createElement('div');
        sender.className = 'msg-sender';
        sender.textContent = msg.fromName;
        bubble.appendChild(sender);
    }
    
    if (msg.replyTo) {
        const quote = document.createElement('div');
        quote.className = 'msg-reply-quote';
        quote.innerHTML = `<strong>${escapeHtml(msg.replyTo.fromName)}:</strong> <em>${escapeHtml(msg.replyTo.message)}</em>`;
        bubble.appendChild(quote);
    }

    if (msg.message) {
        const text = document.createElement('div');
        text.innerHTML = formatChatMessage(msg.message);
        bubble.appendChild(text);
    }
    
    if (msg.image) {
        const attachmentsContainer = document.createElement('div');
        attachmentsContainer.className = 'chat-attachments-container';
        const urls = msg.image.split('\n');
        urls.forEach(url => {
            if (url.trim()) {
                const isImg = /\.(jpg|jpeg|png|gif)$/i.test(url);
                const attachEl = document.createElement('div');
                attachEl.className = `chat-attachment ${isImg ? 'chat-attachment--image' : 'chat-attachment--file'}`;
                const link = document.createElement('a');
                link.href = url;
                link.target = '_blank';

                if (isImg) {
                    const img = document.createElement('img');
                    img.src = url.replace('/view', '/thumbnail');
                    link.appendChild(img);
                } else {
                    link.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="currentColor"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79 4-4 4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/></svg><span>${getFileNameFromUrl(url)}</span>`;
                }
                attachEl.appendChild(link);
                attachmentsContainer.appendChild(attachEl);
            }
        });
        bubble.appendChild(attachmentsContainer);
    }

    const time = document.createElement('span');
    time.className = 'msg-time';
    time.textContent = msg.timestamp;
    bubble.appendChild(time);
    
    const actions = document.createElement('div');
    actions.className = 'msg-actions';
    actions.innerHTML = `<span class="msg-reply-btn" title="Responder" onclick="setReplyContext(${msg.id}, '${escapeHtml(msg.fromName)}', '${escapeHtml(msg.message.substring(0,50))}')">↪</span>`;
    bubble.appendChild(actions);

    wrapper.appendChild(bubble);
    
    if (msg.replies && msg.replies.length > 0) {
        const threadDiv = document.createElement('div');
        threadDiv.className = 'chat-thread';
        msg.replies.forEach(reply => {
            threadDiv.appendChild(createMessageElement(reply));
        });
        wrapper.appendChild(threadDiv);
    }
    
    return wrapper;
}

function findNewestMessage(messages) {
    let newest = null;
    function traverse(msgs) {
        for (const msg of msgs) {
            if (!newest || msg.id > newest.id) {
                newest = msg;
            }
            if (msg.replies && msg.replies.length > 0) {
                traverse(msg.replies);
            }
        }
    }
    traverse(messages);
    return newest;
}

function formatChatMessage(text) {
    text = escapeHtml(text).replace(/@(\w+)/g, (match, username) => {
        if (loggedUser && username.toLowerCase() === loggedUser.nome.toLowerCase()) {
            return `<span class="mention-me">${match}</span>`;
        }
        return `<span class="mention-other">${match}</span>`;
    });
    text = text.replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank">$1</a>');
    return text;
}

function setReplyContext(id, fromName, message) {
    chatReplyContext = { id, fromName, message: message.replace(/'/g, "\\'") };
    const previewContainer = document.getElementById('chat-reply-preview-container');
    if(previewContainer) {
        previewContainer.innerHTML = `
          <div class="chat-reply-preview">
            <div class="chat-reply-preview-close" onclick="cancelReply()">&times;</div>
            <div class="chat-reply-preview-header">Respondendo a ${escapeHtml(fromName)}</div>
            <div class="chat-reply-preview-text">${escapeHtml(message)}</div>
          </div>
        `;
    }
    const input = document.getElementById('chat-input-text');
    if(input) input.focus();
}

function cancelReply() {
    chatReplyContext = null;
    const previewContainer = document.getElementById('chat-reply-preview-container');
    if(previewContainer) previewContainer.innerHTML = '';
}

function getFileNameFromUrl(url) {
    try {
        const decodedUrl = decodeURIComponent(url);
        return decodedUrl.substring(decodedUrl.lastIndexOf('/') + 1);
    } catch (e) { return "Arquivo"; }
}


