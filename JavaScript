                            };
                            if (this._successHandler) this._successHandler(mockStats);
                        } else if (this._failureHandler) {
                            this._failureHandler(res.error);
                        }
                    }
                })
                .catch(err => {
                    if (this._failureHandler) this._failureHandler(err);
                });
            },
            verificarLogin: function(n, s) { this._call('verificarLogin', n, s); },
            getInitialData: function(e) { this._call('getInitialData', e); },
            getDashboardStatistics: function(e, d1, d2) { this._call('getDashboardStatistics', e, d1, d2); },
            filtrarOSPainel: function(f, p, s) { this._call('filtrarOSPainel', f, p, s); },
