function renderPaginationControls() {
    const container = document.getElementById('pagination-container');
    if (!container) return;
    const { currentPage, pageSize, totalItems } = osPaginationState;
    const totalPages = Math.ceil(totalItems / pageSize);

    if (totalItems <= 0) {
        container.innerHTML = '<span class="pagination-info">Nenhum item encontrado.</span>';
        return;
    }

    let html = `
        <div class="pagination-info">
            Exibindo <strong>${Math.min((currentPage - 1) * pageSize + 1, totalItems)}</strong> - <strong>${Math.min(currentPage * pageSize, totalItems)}</strong> de <strong>${totalItems}</strong> itens
        </div>
        <div class="pagination-controls-wrapper">
            <div class="pagination-page-size">
                <label for="os-page-size">Itens por página:</label>
                <select id="os-page-size" onchange="changeOSPageSize(this.value)">
                    <option value="25" ${pageSize === 25 ? 'selected' : ''}>25</option>
                    <option value="50" ${pageSize === 50 ? 'selected' : ''}>50</option>
                    <option value="100" ${pageSize === 100 ? 'selected' : ''}>100</option>
                    <option value="200" ${pageSize === 200 ? 'selected' : ''}>200</option>
                </select>
            </div>
            <div class="pagination-buttons">
    `;

    // Primeira Página
    html += `<button class="btn btn-secondary" onclick="aplicarFiltroPainel(1)" ${currentPage === 1 ? 'disabled' : ''} title="Primeira Página">«</button>`;
    
    // Anterior
    html += `<button class="btn btn-secondary" onclick="aplicarFiltroPainel(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>Anterior</button>`;

    // Números de Página (Sliding Window)
    const delta = 2;
    const left = currentPage - delta;
    const right = currentPage + delta + 1;
    const range = [];
    const rangeWithDots = [];
    let l;

    for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= left && i < right)) {
            range.push(i);
        }
    }

    for (let i of range) {
        if (l) {
            if (i - l === 2) {
                rangeWithDots.push(l + 1);
            } else if (i - l !== 1) {
                rangeWithDots.push('...');
            }
        }
        rangeWithDots.push(i);
        l = i;
    }

    rangeWithDots.forEach(p => {
        if (p === '...') {
            html += `<span class="pagination-dots">...</span>`;
        } else {
            html += `<button class="btn ${p === currentPage ? 'btn-primary' : 'btn-secondary'}" onclick="aplicarFiltroPainel(${p})">${p}</button>`;
        }
    });

    // Próxima
    html += `<button class="btn btn-secondary" onclick="aplicarFiltroPainel(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>Próxima</button>`;
    
    // Última Página
    html += `<button class="btn btn-secondary" onclick="aplicarFiltroPainel(${totalPages})" ${currentPage === totalPages ? 'disabled' : ''} title="Última Página">»</button>`;

    html += `
            </div>
        </div>
    `;

    container.innerHTML = html;
}

