 */
function handleFileChange(event, displayId = 'anexo-filename-display') {
    const files = event.target.files;
    const dispEl = document.getElementById(displayId);
    if (!files || files.length === 0) {
        filesToUpload = [];
        if(dispEl) dispEl.textContent = '';
        return;
    }
    
    if (files.length > 6) {
        alert("Você pode anexar no máximo 6 arquivos.");
        event.target.value = '';
        return;
    }

    filesToUpload = [];
    let fileNames = [];
    Array.from(files).forEach(file => {
        fileNames.push(file.name);
        fileToBase64(file).then(base64String => {
            filesToUpload.push({ base64: base64String, name: file.name });
        });
    });
    if(dispEl) dispEl.textContent = fileNames.join(', ');
}

function handleDiarioFileChange(e) {
  handleFileChange(e, 'diario-anexo-filename-display');
}

function handleModalFileChange(event) {
    const files = event.target.files;
    if (!files) return;
    modalFilesToUpload = [];
    let fileNames = [];
    Array.from(files).forEach(file => {
        fileNames.push(file.name);
        fileToBase64(file).then(base64String => {
            modalFilesToUpload.push({ base64: base64String, name: file.name });
        });
    });
    const mFn = document.getElementById('modal-anexo-filename');
    if(mFn) mFn.textContent = fileNames.join(', ');
}

function handleChatAttachFiles(event) {
    const files = event.target.files;
    if (!files || files.length === 0) return;
    Array.from(files).forEach(file => {
        fileToBase64(file).then(base64String => {
            chatAttachments.push({ base64: base64String, name: file.name, isImage: file.type.startsWith('image/') });
            renderChatAttachmentsPreview();
        });
    });
}

function renderChatAttachmentsPreview() {
    const container = document.getElementById('chat-attachments-preview');
    if (!container) return;
    container.innerHTML = '';
    if (chatAttachments.length === 0) return;
    
    const list = document.createElement('div');
    list.className = 'chat-attachments-list';
    chatAttachments.forEach((att, idx) => {
        const item = document.createElement('div');
        item.className = 'chat-attachment-item';
        item.innerHTML = `<span>${escapeHtml(att.name)}</span> <span class="chat-attachment-remove" onclick="chatAttachments.splice(${idx}, 1); renderChatAttachmentsPreview();">&times;</span>`;
        list.appendChild(item);
    });
    container.appendChild(list);
}

function fileToBase64(file) {
    return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = () => resolve(reader.result);
        reader.onerror = error => reject(error);
    });
}

