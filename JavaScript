                        `;
                    }
                }
            }
            break;
        case 'relatorios':
            const activeSubRelatorios = document.querySelector('#relatorios .sub-tab-button.active');
            openSubTab(activeSubRelatorios?.dataset.subTab || 'relatorio-os', 'relatorios');
            break;
        case 'configuracoes':
            const activeSubConfig = document.querySelector('#configuracoes .sub-tab-button.active');
            openSubTab(activeSubConfig?.dataset.subTab || 'acesso-senha', 'configuracoes');
            break;
        case 'minha-conta':
            stopPrivateMessageAlarm(); 
            const cpEmail = document.getElementById('cp-email');
            if(cpEmail) cpEmail.value = loggedUser.email;
            showLoading();
            google.script.run.withSuccessHandler(() => {
                hideLoading();
                const bell = document.getElementById('private-message-bell');
                if(bell) bell.style.display = 'none';
            }).withFailureHandler(() => hideLoading()).markMessagesAsRead(loggedUser.email);
            loadMyMessages();
            break;
    }
}

function openSubTab(subTabName, parentTabId) {
    const parent = document.getElementById(parentTabId);
    if (!parent) return;

    parent.querySelectorAll('.sub-tab-content').forEach(c => c.classList.remove('active'));
    parent.querySelectorAll('.sub-tab-button').forEach(b => b.classList.remove('active'));

    parent.querySelector(`.sub-tab-button[data-sub-tab="${subTabName}"]`)?.classList.add('active');
    parent.querySelector(`#${subTabName}-subcontent`)?.classList.add('active');

    if (parentTabId === 'relatorios') {
        switch (subTabName) {
            case 'relatorio-os': loadRelatorioControls(); aplicarFiltroRelatorio(); break;
            case 'relatorio-rotinas': loadRelatorioRotinasControls(); aplicarFiltroRelatorioRotinas(); break;
        }
    } else if (parentTabId === 'configuracoes') {
        switch (subTabName) {
            case 'acesso-senha': loadAdminUsersTable(); break;
            case 'popup': loadPopUpConfigAdmin(); break;
            case 'log-acoes': loadActionLogs(); break;
            case 'enviar-mensagem': loadMessageSender(); break;
        }
    }
}

function showMessage(elId, msg, isSuccess) {
    const el = document.getElementById(elId);
    if (!el) return;
    el.textContent = msg;
    el.className = isSuccess ? 'message success-message' : 'message error-message';
    el.style.display = 'block';
    setTimeout(() => { el.style.display = 'none'; }, 5000);
}

function showToast(message, actions = [], type = '') {
    const toast = document.getElementById('os-toast');
    if(!toast) return;
    toast.className = 'toast show'; 
    if(type === 'new-os') toast.classList.add('toast-new-os');
    if(type === 'high-priority') toast.classList.add('toast-high-priority');
    if(type === 'assigned') toast.classList.add('toast-assigned');
    if(type === 'toast-overdue') toast.classList.add('toast-overdue');

    toast.innerHTML = '';
    const messageDiv = document.createElement('div');
    messageDiv.innerHTML = message;
    toast.appendChild(messageDiv);

    if (actions.length > 0) {
        const actionsContainer = document.createElement('div');
        actionsContainer.className = 'toast-actions';
        actions.forEach(action => {
            const button = document.createElement('button');
            button.className = 'btn btn-secondary';
            button.textContent = action.label;
            button.addEventListener('click', () => {
                if (typeof action.callback === 'function') action.callback();
                toast.classList.remove('show');
            });
            actionsContainer.appendChild(button);
        });
        toast.appendChild(actionsContainer);
    }

    if (actions.length === 0) {
        setTimeout(() => { toast.classList.remove('show'); }, 5000);
    }
}

function getLocalDateString(date) {
    if (!(date instanceof Date) || isNaN(date)) return '';
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
}

function formatDateToDDMMYYYY(dateString) {
    if (!dateString || typeof dateString !== 'string') return '';
    const parts = dateString.split('-');
    if (parts.length !== 3) return dateString;
    return `${parts[2]}/${parts[1]}/${parts[0]}`;
}

function escapeHtml(unsafe) {
    if (typeof unsafe !== 'string') return '';
    return unsafe
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
}

