class DateRangePicker {
    constructor(containerId, defaultKey = 'last7days', onChangeCallback = null) {
        this.container = document.getElementById(containerId);
        if (!this.container) return;
        this.onChangeCallback = onChangeCallback;

        this.currentRange = {
            key: defaultKey,
            ...this.calculateDates(defaultKey)
        };
        this.predefinedRanges = {
            'today': 'Hoje', 
            'yesterday': 'Ontem', 
            'last7days': 'Últimos 7 dias',
            'last30days': 'Últimos 30 dias', 
            'last90days': 'Últimos 90 dias',
            'last6months': 'Últimos 6 meses',
            'last12months': 'Últimos 12 meses',
            'thismonth': 'Este Mês', 
            'lastmonth': 'Mês Passado',
            'thisyear': 'Este Ano',
            'lastyear': 'Ano Passado',
            'all': 'Desde o início', 
            'custom': 'Personalizado'
        };

        this.render();
        // Atribuição dos elementos DEVE vir antes de updateDisplay
        this.displayBtn = this.container.querySelector('.date-range-display-btn');
        this.dropdown = this.container.querySelector('.date-range-dropdown');
        this.customRangeContainer = this.container.querySelector('.custom-range');
        this.startDateInput = this.container.querySelector('.custom-start-date');
        this.endDateInput = this.container.querySelector('.custom-end-date');

        this.updateDisplay();
        
        this.setupEventListeners();
        document.addEventListener('click', this.handleDocumentClick.bind(this));
    }

    render() {
        const predefinedButtons = Object.keys(this.predefinedRanges)
            .filter(key => key !== 'custom' && key !== 'all')
            .map(key => `<button class="predefined-btn" data-key="${key}">${this.predefinedRanges[key]}</button>`)
            .join('');

        this.container.innerHTML = `
            <button class="date-range-display-btn"></button>
            <div class="date-range-dropdown">
                <div class="predefined-ranges">
                    ${predefinedButtons}
                    <button class="predefined-btn" data-key="all">${this.predefinedRanges['all']}</button>
                    <button class="predefined-btn" data-key="custom">${this.predefinedRanges['custom']}</button>
                </div>
                <div class="custom-range">
                    <input type="date" class="custom-start-date">
                    <span>até</span>
                    <input type="date" class="custom-end-date">
                </div>
            </div>
        `;
    }

    setupEventListeners() {
        const applyCustomDateChange = () => {
            this.currentRange = {
                key: 'custom',
                startDate: this.startDateInput.value,
                endDate: this.endDateInput.value
            };
            this.updateDisplay();
            if (this.onChangeCallback) this.onChangeCallback();
        };

        this.startDateInput.addEventListener('change', applyCustomDateChange);
        this.endDateInput.addEventListener('change', applyCustomDateChange);

        this.displayBtn.addEventListener('click', () => {
            this.container.classList.toggle('open');
            // Também tenta alternar no pai se existir para compatibilidade com CSS antigo
            if(this.container.parentElement.classList.contains('date-range-container')) {
                this.container.parentElement.classList.toggle('open');
            }
        });
        
        this.container.querySelectorAll('.predefined-btn').forEach(btn => {
            btn.addEventListener('click', (e) => this.handlePredefinedClick(e.target.dataset.key));
        });
    }

    handlePredefinedClick(key) {
        this.currentRange.key = key;
        if (key === 'custom') {
            this.customRangeContainer.classList.add('active');
            this.updateActiveButton();
        } else {
            this.customRangeContainer.classList.remove('active');
            this.currentRange = { key, ...this.calculateDates(key) };
            this.updateDisplay();
            this.container.classList.remove('open');
            if(this.container.parentElement.classList.contains('date-range-container')) {
                this.container.parentElement.classList.remove('open');
            }
            if (this.onChangeCallback) this.onChangeCallback();
        }
    }

    handleDocumentClick(e) {
        if (!this.container.contains(e.target)) {
            this.container.classList.remove('open');
            if(this.container.parentElement.classList.contains('date-range-container')) {
                this.container.parentElement.classList.remove('open');
            }
        }
    }

    updateDisplay() {
        if (!this.displayBtn) return;
        if (this.currentRange.key === 'custom') {
            if (this.currentRange.startDate && this.currentRange.endDate) {
                 const formattedStart = formatDateToDDMMYYYY(this.currentRange.startDate);
                 const formattedEnd = formatDateToDDMMYYYY(this.currentRange.endDate);
                 this.displayBtn.textContent = `${formattedStart} - ${formattedEnd}`;
            } else {
                 this.displayBtn.textContent = 'Selecione um intervalo';
            }
        } else {
            this.displayBtn.textContent = this.predefinedRanges[this.currentRange.key];
        }
        this.updateActiveButton();
    }
    
    updateActiveButton() {
        this.container.querySelectorAll('.predefined-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.key === this.currentRange.key);
        });
    }

    calculateDates(key) {
        const now = new Date();
        let start = new Date();
        let end = new Date();
        
        switch (key) {
            case 'today':
                start.setHours(0, 0, 0, 0); end.setHours(23, 59, 59, 999); break;
            case 'yesterday':
                start.setDate(now.getDate() - 1); start.setHours(0, 0, 0, 0);
                end.setDate(now.getDate() - 1); end.setHours(23, 59, 59, 999); break;
            case 'last7days':
                start.setDate(now.getDate() - 6); start.setHours(0, 0, 0, 0); end.setHours(23, 59, 59, 999); break;
            case 'last30days':
                start.setDate(now.getDate() - 29); start.setHours(0, 0, 0, 0); end.setHours(23, 59, 59, 999); break;
            case 'thismonth':
                start = new Date(now.getFullYear(), now.getMonth(), 1); end = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59, 999); break;
            case 'lastmonth':
                start = new Date(now.getFullYear(), now.getMonth() - 1, 1); end = new Date(now.getFullYear(), now.getMonth(), 0, 23, 59, 59, 999); break;
            case 'last90days':
                start.setDate(now.getDate() - 89); start.setHours(0, 0, 0, 0); end.setHours(23, 59, 59, 999); break;
            case 'last6months':
                start.setMonth(now.getMonth() - 6); start.setHours(0, 0, 0, 0); end.setHours(23, 59, 59, 999); break;
            case 'last12months':
                start.setFullYear(now.getFullYear() - 1); start.setHours(0, 0, 0, 0); end.setHours(23, 59, 59, 999); break;
            case 'thisyear':
                start = new Date(now.getFullYear(), 0, 1); end = new Date(now.getFullYear(), 11, 31, 23, 59, 59, 999); break;
            case 'lastyear':
                start = new Date(now.getFullYear() - 1, 0, 1); end = new Date(now.getFullYear() - 1, 11, 31, 23, 59, 59, 999); break;
            case 'all':
                return { startDate: null, endDate: null };
        }
        return { startDate: getLocalDateString(start), endDate: getLocalDateString(end) };
    }

    getDateRange() {
        return this.currentRange;
    }
}

