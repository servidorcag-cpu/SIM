// Permite arrastar a janela de chat pela tela
function setupChatWindowDrag() {
    const chatWin = document.getElementById('chat-floating-window');
    const chatHeader = document.querySelector('.chat-header');
    if (!chatWin || !chatHeader) return;
    
    let isDragging = false;
    let currentX, currentY, initialX, initialY;
    let xOffset = 0, yOffset = 0;

    chatHeader.addEventListener('mousedown', dragStart);
    document.addEventListener('mousemove', drag);
    document.addEventListener('mouseup', dragEnd);

    function dragStart(e) {
        initialX = e.clientX - xOffset;
        initialY = e.clientY - yOffset;
        if (e.target === chatHeader || chatHeader.contains(e.target)) {
            isDragging = true;
        }
    }

    function drag(e) {
        if (isDragging) {
            e.preventDefault();
            currentX = e.clientX - initialX;
            currentY = e.clientY - initialY;
            xOffset = currentX;
            yOffset = currentY;
            chatWin.style.transform = `translate(${currentX}px, ${currentY}px)`;
        }
    }

    function dragEnd(e) {
        initialX = currentX;
        initialY = currentY;
        isDragging = false;
    }
}

// Pop-Up de Login Admin
function loadPopUpOnLoginScreen() {
    if (typeof google === 'undefined' || !google.script) return;
    google.script.run.withSuccessHandler(config => {
        if (config && config.habilitado === 'TRUE') {
            const modal = document.getElementById('popup-modal');
            const msgEl = document.getElementById('popup-modal-message');
            const imgEl = document.getElementById('popup-modal-image');
            
            if (modal && msgEl) {
                msgEl.innerHTML = config.mensagem.replace(/\n/g, '<br>');
                if (config.imageUrl && imgEl) {
                    imgEl.src = config.imageUrl;
                    imgEl.style.display = 'block';
                } else if (imgEl) {
                    imgEl.style.display = 'none';
                }
                modal.style.display = 'block';
            }
        }
    }).getConfiguracaoPopUp();
}

// WakeLock API (Impede a tela do celular de apagar)
async function requestWakeLock() {
    try {
        if ('wakeLock' in navigator) {
            wakeLock = await navigator.wakeLock.request('screen');
        }
    } catch (err) {
        console.warn(`${err.name}, ${err.message}`);
    }
}

function releaseWakeLock() {
    if (wakeLock !== null) {
        wakeLock.release().then(() => wakeLock = null);
    }
}

function handleWakeLockVisibility() {
    if (document.visibilityState === 'visible' && loggedUser) {
        requestWakeLock();
    }
}
