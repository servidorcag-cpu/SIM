function saveOSDraft() {
    const descEl = document.getElementById('os-descricao');
    if (!descEl || !descEl.value.trim()) { clearOSDraft(); return; }
    try {
        STORAGE_API.setItem(DRAFT_OS_KEY, JSON.stringify({
            setor: document.getElementById('os-setor')?.value,
            descricao: descEl.value,
            prioridade: document.getElementById('os-prioridade')?.value,
            tecnico: document.getElementById('os-tecnico')?.value || ''
        }));
    } catch (e) {}
}

function clearOSDraft() {
    try { STORAGE_API.removeItem(DRAFT_OS_KEY); } catch (e) {}
}

function checkForOSDraft() {
    try {
        const savedDraft = STORAGE_API.getItem(DRAFT_OS_KEY);
        if (savedDraft) {
            const draftData = JSON.parse(savedDraft);
            showToast("📝 <strong>Rascunho de O.S. encontrado!</strong>", [
                { label: 'Restaurar', callback: () => {
                    const elS = document.getElementById('os-setor'); if(elS) elS.value = draftData.setor || '';
                    const elD = document.getElementById('os-descricao'); if(elD) elD.value = draftData.descricao || '';
                    const elP = document.getElementById('os-prioridade'); if(elP) elP.value = draftData.prioridade || 'Média';
                    const tecEl = document.getElementById('os-tecnico'); if (tecEl) tecEl.value = draftData.tecnico || '';
                }},
                { label: 'Descartar', callback: () => { clearOSDraft(); showToast("Rascunho descartado."); } }
