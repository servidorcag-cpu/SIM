    if (!isChartsLoaded || typeof google === 'undefined' || !google.visualization || !google.visualization.arrayToDataTable) {
        console.warn("Google Charts ainda não carregado ou visualização indisponível. Aguardando...");
        setTimeout(() => renderDashboardStats(stats), 800);
        return;
    }

    try {
        // 1. Gráfico de Status
        const statusContainer = document.getElementById('status-column-chart');
        if (statusContainer && stats.chartData && stats.chartData.length > 1) {
            const statusData = google.visualization.arrayToDataTable(stats.chartData);
            const statusOptions = { 
                title:'O.S. por Status', 
                backgroundColor: 'transparent', 
                legend: {textStyle: {color: '#CBD2F1'}}, 
                titleTextStyle: {color: '#CBD2F1'}, 
                hAxis:{textStyle:{color:'#CBD2F1'}}, 
                vAxis:{textStyle:{color:'#CBD2F1'}, gridlines: {color: '#334155'}} 
            };
