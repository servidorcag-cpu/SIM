        console.error("Nenhum dado de estatística recebido.");
        return;
    }

    const container = document.getElementById('stats-dashboard-container');
    if (container) {
        container.innerHTML = `
          <div class="stat-card"><div class="stat-number">${stats.total || 0}</div><div>Total de O.S.</div></div>
          <div class="stat-card"><div class="stat-number" style="color: var(--secondary-color);">${stats.abertas || 0}</div><div>Abertas</div></div>
          <div class="stat-card"><div class="stat-number" style="color: var(--warning-color);">${stats.andamento || 0}</div><div>Em Andamento</div></div>
