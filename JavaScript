    const tbody = document.querySelector('#admin-logs-table tbody');
    if(!tbody) return;
    let html = '';
    if (logs && logs.length > 0) {
        logs.forEach(log => {
            html += `<tr><td>${log[0]}</td><td>${escapeHtml(log[1])}</td><td>${escapeHtml(log[2])}</td><td>${escapeHtml(log[3])}</td></tr>`;
        });
