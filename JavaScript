function checkForOverdueOS() {
    if (!loggedUser || loggedUser.nivel.toLowerCase() !== 'admin') return;
    google.script.run
        .withSuccessHandler(handleOverdueOSCheck)
        .withFailureHandler(err => console.error("Falha ao verificar O.S. em atraso:", err))
        .getOverdueOS();
}

function handleOverdueOSCheck(overdueIds) {
    const ids = overdueIds || [];
    if (ids.length === 0) {
        if (alarmingOverdueOSIds.length > 0) stopOverdueAlarm(true);
        return;
    }
    const hasNewOverdue = ids.some(id => !alarmingOverdueOSIds.includes(id));
    const listHasChanged = hasNewOverdue || ids.length !== alarmingOverdueOSIds.length;

    if (listHasChanged) {
        alarmingOverdueOSIds = ids;
        startOverdueAlarm();
    }
}

function startOverdueAlarm() {
    const header = document.querySelector('header');
    if(header) header.classList.add('overdue-alert');
    const message = `<strong>ALERTA:</strong> Existem ${alarmingOverdueOSIds.length} O.S. abertas/pendentes há mais de 7 dias!`;
    showToast(message, [{ label: 'Ver Painel', callback: () => openTab('painel-os') }], 'toast-overdue');

    if (!overdueAudioLoopInterval) {
        playWarningBeep();
        overdueAudioLoopInterval = setInterval(playWarningBeep, AUDIO_INTERVAL);
    }
    const painelOS = document.getElementById('painel-os');
    if (painelOS && painelOS.classList.contains('active')) aplicarFiltroPainel();
}

function stopOverdueAlarm(fullReset = false) {
    const header = document.querySelector('header');
    if(header) header.classList.remove('overdue-alert');
    if (overdueAudioLoopInterval) {
        clearInterval(overdueAudioLoopInterval);
        overdueAudioLoopInterval = null;
    }
    if (fullReset) alarmingOverdueOSIds = [];
}

