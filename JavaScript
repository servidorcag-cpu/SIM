function renderRelatorioTable(data) {
    hideLoading();
    const table = document.getElementById('relatorios-table-os');
    if (!table) return;
    
    let html = '<thead><tr><th>ID</th><th>Data</th><th>Solicitante</th><th>Setor</th><th>Descrição</th><th>Status</th><th>Técnico</th><th>Prioridade</th></tr></thead><tbody>';
    
    try {
        let processedGroups = null;

        if (data && typeof data === 'object' && !Array.isArray(data) && data.groups) {
            processedGroups = data.groups;
        } else if (Array.isArray(data) && data.length > 0) {
            processedGroups = {};
            data.forEach(row => {
                const status = row[6] || 'Desconhecido';
                if (!processedGroups[status]) {
                    processedGroups[status] = { count: 0, items: [] };
                }
                processedGroups[status].items.push(row);
                processedGroups[status].count++;
            });
        }

        if (!processedGroups || Object.keys(processedGroups).length === 0) {
            html += '<tr><td colspan="8" style="text-align: center;">Nenhum registo encontrado.</td></tr>';
        } else {
            for (const status in processedGroups) {
                const group = processedGroups[status];
                html += `
                    <tr class="group-header" style="background: rgba(127, 90, 240, 0.15);">
                        <td colspan="8" style="text-align: center; font-weight: bold; color: var(--primary-color);">
                            Status: ${escapeHtml(status)} (${group.count} O.S.)
                        </td>
                    </tr>`;
                
                group.items.forEach(row => {
                    html += `<tr>
                        <td>${row[0]}</td>
                        <td>${row[1]}</td>
                        <td>${row[3]}</td>
                        <td>${row[4]}</td>
                        <td>${escapeHtml(row[5])}</td>
                        <td>${row[6]}</td>
                        <td>${row[7]}</td>
                        <td>${escapeHtml(row[9])}</td>
                    </tr>`;
                });
            }
        }
    } catch (e) {
        html += `<tr><td colspan="8" style="color: red; text-align: center;">Erro interno: ${e.message}</td></tr>`;
    }
    
    html += '</tbody>';
    table.innerHTML = html;
}

