function submitDiarioTecnico() {
    const desc = document.getElementById('diario-descricao').value.trim();
    if (!desc) { showMessage('diario-message', 'A descrição não pode estar vazia.', false); return; }

    let tecnicoNome = '';
    const userLevel = loggedUser.nivel.toLowerCase();

    if (userLevel === 'admin' || userLevel === 'gerente') {
        const tecnicoSelect = document.getElementById('diario-tecnico-select');
        if (tecnicoSelect && tecnicoSelect.value) {
            tecnicoNome = tecnicoSelect.value;
        } else {
            showMessage('diario-message', 'Por favor, selecione um técnico.', false); return;
        }
    } else if (userLevel === 'tecnico') {
        tecnicoNome = loggedUser.nome;
    }

    if (!tecnicoNome) {
        showMessage('diario-message', 'Não foi possível identificar o técnico.', false); return;
    }

    const dateValue = document.getElementById('diario-data').value;
    
    showLoading();
    google.script.run
        .withSuccessHandler(res => {
            hideLoading();
            if (res.status === 'sucesso') {
                showMessage('diario-message', 'Registro salvo!', true);
                document.getElementById('diario-descricao').value = '';
                filesToUpload = [];
                const inputAnexo = document.getElementById('diario-anexo-input'); if(inputAnexo) inputAnexo.value = '';
                const display = document.getElementById('diario-anexo-filename-display'); if(display) display.textContent = '';
                if (loggedUser.nivel.toLowerCase() === 'admin' || loggedUser.nivel.toLowerCase() === 'gerente') {
                    const tecnicoSelect = document.getElementById('diario-tecnico-select');
                    if (tecnicoSelect) tecnicoSelect.value = '';
                }
            } else {
                showMessage('diario-message', 'Falha ao salvar: ' + (res.message || 'Erro desconhecido.'), false);
            }
        })
        .withFailureHandler(() => hideLoading())
        .salvarDiarioTecnico(dateValue, tecnicoNome, desc, filesToUpload);
}

