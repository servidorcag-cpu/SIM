function startPollingServices() {
    if (!chatPollingInterval) {
        chatPollingInterval = setInterval(() => loadGlobalChatHistory(false, true), FAST_INTERVAL);
    }
    if (!overdueCheckInterval && loggedUser.nivel.toLowerCase() === 'admin') {
        overdueCheckInterval = setInterval(checkForOverdueOS, 300000); 
        checkForOverdueOS();
    }
    if (!privateMsgCheckInterval) {
        privateMsgCheckInterval = setInterval(checkForPrivateMessages, SLOW_INTERVAL);
        checkForPrivateMessages();
    }
    if (loggedUser.nivel.toLowerCase() === 'tecnico') {
        if (!assignmentCheckInterval) {
            assignmentCheckInterval = setInterval(checkForNewAssignment, FAST_INTERVAL);
            checkForNewAssignment(); 
        }
    }
}

function stopAllPollingServices() {
    if (osCheckInterval) clearInterval(osCheckInterval);
    if (updateCheckInterval) clearInterval(updateCheckInterval);
    if (chatPollingInterval) clearInterval(chatPollingInterval);
    if (highPriorityInterval) clearInterval(highPriorityInterval);
    if (overdueCheckInterval) clearInterval(overdueCheckInterval);
    if (privateMsgCheckInterval) clearInterval(privateMsgCheckInterval);
    if (assignmentCheckInterval) clearInterval(assignmentCheckInterval);
    osCheckInterval = updateCheckInterval = chatPollingInterval = highPriorityInterval = overdueCheckInterval = privateMsgCheckInterval = assignmentCheckInterval = null;
}

function stopAllAudioLoops(){
    if (audioLoopInterval) clearInterval(audioLoopInterval);
    if (remoteAudioLoopInterval) clearInterval(remoteAudioLoopInterval);
    if (chatAudioLoopInterval) clearInterval(chatAudioLoopInterval);
    if (highPriorityAudioLoop) clearInterval(highPriorityAudioLoop);
    if (overdueAudioLoopInterval) clearInterval(overdueAudioLoopInterval);
    if (privateMsgAudioLoop) clearInterval(privateMsgAudioLoop);
    if (assignmentAudioLoopInterval) clearInterval(assignmentAudioLoopInterval);
    audioLoopInterval = remoteAudioLoopInterval = chatAudioLoopInterval = highPriorityAudioLoop = overdueAudioLoopInterval = privateMsgAudioLoop = assignmentAudioLoopInterval = null;
}

