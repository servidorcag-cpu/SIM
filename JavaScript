            statusChart.draw(statusData, statusOptions);
        }

        // 2. Gráfico de Setores
        const sectorContainer = document.getElementById('sector-pie-chart');
        if(sectorContainer && stats.sectorChartData && stats.sectorChartData.length > 1) {
            const sectorData = google.visualization.arrayToDataTable(stats.sectorChartData);
            const sectorOptions = { 
                title: 'O.S. Criadas por Setor', 
                backgroundColor: 'transparent', 
                legend: {textStyle: {color: '#CBD2F1'}, position: 'right'}, 
                titleTextStyle: {color: '#CBD2F1'}, 
                pieHole: 0.4,
                chartArea: { width: '90%', height: '80%' }
            };
            const sectorChart = new google.visualization.PieChart(sectorContainer);
            sectorChart.draw(sectorData, sectorOptions);
        }

        // 3. Gráfico de Performance dos Técnicos
        const techContainer = document.getElementById('tech-performance-chart');
        if(techContainer && stats.techPerformanceData && stats.techPerformanceData.length > 1) {
            const techData = google.visualization.arrayToDataTable(stats.techPerformanceData);
            const techOptions = { 
                title: 'Performance dos Técnicos (OS vs Diário)', 
                backgroundColor: 'transparent', 
                legend: {position: 'top', textStyle: {color: '#CBD2F1'}}, 
                titleTextStyle: {color: '#CBD2F1'}, 
                hAxis:{textStyle:{color:'#CBD2F1'}}, 
                vAxis:{textStyle:{color:'#CBD2F1'}, gridlines: {color: 'transparent'}}, 
                seriesType: 'bars' 
            };
            const techChart = new google.visualization.ComboChart(techContainer);
            techChart.draw(techData, techOptions);
        }
        
        // 4. Gráfico de Ontem
        const yesterdayContainer = document.getElementById('yesterday-completed-chart');
        if (yesterdayContainer && stats.yesterdayTechPerformanceChartData && stats.yesterdayTechPerformanceChartData.length > 1) {
            const yesterdayData = google.visualization.arrayToDataTable(stats.yesterdayTechPerformanceChartData);
            const yesterdayOptions = {
                title: 'Atividades Concluídas Ontem por Técnico',
                backgroundColor: 'transparent',
                legend: { textStyle: { color: '#CBD2F1' } },
                titleTextStyle: { color: '#CBD2F1' },
                hAxis: { textStyle: { color: '#CBD2F1' } },
                vAxis: { textStyle: { color: '#CBD2F1' } },
