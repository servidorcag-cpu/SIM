function openUserModal(email) {
    const modal = document.getElementById('user-admin-modal');
    const title = document.getElementById('user-modal-title');
    const emailEl = document.getElementById('user-email');
    const nomeEl = document.getElementById('user-nome');
    const nivelEl = document.getElementById('user-nivel');
    const senhaEl = document.getElementById('user-senha');
    const deleteBtn = document.getElementById('user-modal-delete-btn');

    emailEl.value = ''; nomeEl.value = ''; nivelEl.value = 'Solicitante'; senhaEl.value = '';
    senhaEl.placeholder = 'Deixe em branco para não alterar';
    showMessage('user-modal-message', '', true);

    if (email) { 
        const user = adminUserListCache.find(u => u[0] === email);
        if (user) {
            title.textContent = 'Editar Utilizador';
            emailEl.value = user[0]; emailEl.disabled = true;
            nomeEl.value = user[1]; nivelEl.value = user[2];
            deleteBtn.style.display = 'block';
        }
    } else { 
        title.textContent = 'Novo Utilizador';
        emailEl.disabled = false;
        senhaEl.placeholder = 'Senha é obrigatória para novo usuário';
        deleteBtn.style.display = 'none';
    }
    if(modal) modal.style.display = 'block';
}

